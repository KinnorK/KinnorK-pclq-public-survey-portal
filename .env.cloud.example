APP_ENV=production
APP_NAME=PCLQ Public Survey and Research Portal
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
SECRET_KEY=replace-with-a-random-secret-at-least-32-characters
PUBLIC_BASE_URL=https://your-public-domain.example
APP_TIMEZONE=Asia/Kolkata
SESSION_HTTPS_ONLY=true
FOUNDER_USERNAME=admin
FOUNDER_PASSWORD=replace-with-a-strong-founder-password
ANALYST_USERNAME=analyst
ANALYST_PASSWORD=replace-with-a-different-strong-analyzer-password
MINIMUM_CORE_ITEMS=16
PRORATE_LIKERT_IF_ONE_MISSING=false
